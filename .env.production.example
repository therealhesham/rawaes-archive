APP_NAME="روائس"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://archive.yourdomain.com
APP_TIMEZONE=Asia/Riyadh
APP_LOCALE=ar

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Database (from Coolify MySQL service)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=rawaes
DB_USERNAME=rawaes
DB_PASSWORD=

# Redis (from Coolify Redis service)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache & Queue → Redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# File Storage (local volume - mount persistent in Coolify)
FILESYSTEM_DISK=local

# Mail (use Resend or SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="روائس"

# OCR
OCR_SPACE_API_KEY=K82554853788957

# Scanner watcher API token (used by watcher.py on office PCs)
SCAN_API_TOKEN=

# Security
BCRYPT_ROUNDS=12
